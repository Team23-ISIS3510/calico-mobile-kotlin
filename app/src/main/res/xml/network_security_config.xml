<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    <!-- Use deployed backend domain; cleartext not required for HTTPS -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">backend-th7q.onrender.com</domain>
    </domain-config>
</network-security-config>